---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import FeedCard from "@components/FeedCard.astro";
import FeedFilter from "@components/FeedFilter.astro";
import InfiniteFeed from "@components/InfiniteFeed.astro";
import Sidebar from "@components/Sidebar.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getPostType from "@utils/getPostType";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getCollection("blog");
  const sorted = getSortedPosts(posts);
  const devlogs = sorted.filter(p => getPostType(p) === "devlog");
  return paginate(devlogs, { pageSize: 25 });
};

const { page } = Astro.props;
---

<Layout>
  <Header />
  <main id="main-content">
    <div class="two-col">
      <div class="feed-col">
        <FeedFilter />
        <InfiniteFeed nextPage={page.url.next ?? null}>
          {page.data.map(post => (
            <div
              data-post-type={getPostType(post)}
              class="feed-item border-b border-skin-line"
            >
              <FeedCard post={post} />
            </div>
          ))}
        </InfiniteFeed>
      </div>
      <div class="sidebar-col">
        <Sidebar />
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .two-col {
    @apply mx-auto flex max-w-6xl flex-col gap-8 px-4 pb-12 pt-4 lg:flex-row;
  }
  .feed-col {
    @apply min-w-0 lg:w-2/3;
  }
  .sidebar-col {
    @apply lg:w-1/3;
  }
  @media (max-width: 1023px) {
    .feed-col {
      padding-bottom: 8rem;
    }
  }
</style>

---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import FeedFilter from "@components/FeedFilter.astro";
import FeedSection from "@components/FeedSection.astro";
import HomeHero from "@components/HomeHero.astro";
import Sidebar from "@components/Sidebar.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getPostType from "@utils/getPostType";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getCollection("blog");
  const sorted = getSortedPosts(posts);
  const weblogs = sorted.filter(p => getPostType(p) === "weblog" && !p.data.featured);
  return paginate(weblogs, { pageSize: 25 });
};

const { page } = Astro.props;
const allPosts = await getCollection("blog");
const featuredPosts = page.currentPage === 1
  ? getSortedPosts(allPosts).filter(p => getPostType(p) === "weblog" && p.data.featured)
  : [];
const nextFeedPage = page.url.next ? `/feed/weblog/${page.currentPage + 1}` : null;
---

<Layout>
  <Header />
  <main id="main-content">
    <HomeHero />
    <div class="two-col">
      <div class="feed-col">
        <FeedFilter />
        <FeedSection
          featuredPosts={featuredPosts}
          posts={page.data}
          nextPage={nextFeedPage}
        />
      </div>
      <div class="sidebar-col">
        <Sidebar />
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .two-col {
    @apply mx-auto flex max-w-6xl flex-col gap-8 px-4 pb-12 pt-4 lg:flex-row;
  }
  .feed-col {
    @apply min-w-0 lg:w-2/3;
  }
  .sidebar-col {
    @apply lg:w-1/3;
  }
  @media (max-width: 1023px) {
    .feed-col {
      padding-bottom: 8rem;
    }
  }
</style>

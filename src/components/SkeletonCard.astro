---
// Placeholder card that matches WeblogCard height while the next page loads.
---

<div class="skeleton-card py-4" aria-hidden="true">
  <div class="mb-2 flex items-center gap-2">
    <div class="skel h-5 w-14 rounded-full"></div>
    <div class="skel h-4 w-24 rounded"></div>
  </div>
  <div class="mb-2 flex gap-4">
    <div class="flex-grow">
      <div class="skel mb-2 h-4 w-3/4 rounded"></div>
      <div class="skel mb-1 h-3 w-full rounded"></div>
      <div class="skel h-3 w-2/3 rounded"></div>
      <div class="mt-2 flex items-center gap-1.5">
        <div class="skel h-3 w-3 rounded-full"></div>
        <div class="skel h-3 w-24 rounded"></div>
      </div>
    </div>
    <div class="skel hidden h-20 w-20 flex-shrink-0 rounded sm:block"></div>
  </div>
</div>

<style>
  .skel {
    background-color: rgb(var(--color-border));
    animation: pulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>

---
const { pathname } = Astro.url;
const activeFilter = pathname.startsWith("/weblog")
  ? "weblog"
  : pathname.startsWith("/devlog")
    ? "devlog"
    : pathname.startsWith("/writing")
      ? "writing"
      : "all";

const filters = [
  { id: "all", label: "all", href: "/" },
  { id: "weblog", label: "weblogs", href: "/weblog" },
  { id: "devlog", label: "devlogs", href: "/devlog" },
  { id: "writing", label: "writings", href: "/writing" },
] as const;
---

<nav
  class="feed-filter mb-6 flex flex-wrap gap-2"
  aria-label="Post type filter"
>
  {
    filters.map(({ id, label, href }) => (
      <button
        type="button"
        class:list={["filter-btn", { active: activeFilter === id }]}
        data-filter={id}
        data-fragment-url={`/feed/${id}`}
        data-route-url={href}
        aria-current={activeFilter === id ? "page" : undefined}
      >
        {label}
      </button>
    ))
  }
</nav>

<style>
  .filter-btn {
    @apply rounded border border-skin-line px-3 py-1 text-sm text-skin-base transition-colors;
    font-family: "IBM Plex Mono", monospace;
    cursor: pointer;
    background: transparent;
    text-decoration: none;
  }
  .filter-btn:hover {
    @apply border-skin-accent text-skin-accent;
  }
  .filter-btn.active {
    @apply border-skin-accent bg-skin-accent/10 text-skin-accent;
  }
</style>

<script>
  type FeedFilterState = {
    bound: boolean;
    cache: Map<string, string>;
    controller: AbortController | null;
  };

  declare global {
    interface Window {
      __feedFilterState?: FeedFilterState;
    }
  }

  const state = (window.__feedFilterState ??= {
    bound: false,
    cache: new Map(),
    controller: null,
  });

  function getButtons() {
    return Array.from(
      document.querySelectorAll<HTMLButtonElement>(
        ".filter-btn[data-filter][data-fragment-url][data-route-url]",
      ),
    );
  }

  function setActive(filter: string) {
    getButtons().forEach((button) => {
      const active = button.dataset.filter === filter;
      button.classList.toggle("active", active);
      if (active) {
        button.setAttribute("aria-current", "page");
      } else {
        button.removeAttribute("aria-current");
      }
    });
  }

  function parseFeedSection(html: string): HTMLElement {
    const doc = new DOMParser().parseFromString(html, "text/html");
    const incoming = doc.getElementById("feed-section");
    if (!incoming) throw new Error("Missing #feed-section in response");
    return incoming;
  }

  async function loadFragment(url: string, signal?: AbortSignal) {
    const cached = state.cache.get(url);
    if (cached) return cached;

    const response = await fetch(url, { signal });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);

    const html = await response.text();
    parseFeedSection(html);
    state.cache.set(url, html);
    return html;
  }

  async function replaceFeedSection(
    current: HTMLElement,
    incoming: HTMLElement,
  ) {
    const startViewTransition = (
      document as Document & {
        startViewTransition?: (callback: () => void) => {
          finished: Promise<void>;
        };
      }
    ).startViewTransition?.bind(document);

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (!startViewTransition || reduceMotion) {
      current.replaceWith(incoming);
      return;
    }

    const transition = startViewTransition(() => {
      current.replaceWith(incoming);
    });
    await transition.finished.catch(() => {});
  }

  function prefetch(button: HTMLButtonElement) {
    const url = button.dataset.fragmentUrl;
    if (!url || state.cache.has(url)) return;
    loadFragment(url).catch(() => {});
  }

  function cacheCurrentSection() {
    const current = document.getElementById("feed-section");
    const activeButton = getButtons().find((button) =>
      button.classList.contains("active"),
    );
    const fragmentUrl = activeButton?.dataset.fragmentUrl;
    if (current && fragmentUrl) {
      state.cache.set(fragmentUrl, current.outerHTML);
    }
  }

  function filterForPath(pathname: string) {
    if (pathname.startsWith("/weblog")) return "weblog";
    if (pathname.startsWith("/devlog")) return "devlog";
    if (pathname.startsWith("/writing")) return "writing";
    return "all";
  }

  async function applyFilter(
    button: HTMLButtonElement,
    mode: "push" | "replace" = "push",
  ) {
    const current = document.getElementById("feed-section");
    const filter = button.dataset.filter;
    const fragmentUrl = button.dataset.fragmentUrl;
    if (!current || !filter || !fragmentUrl) return;

    const previousFilter =
      getButtons().find((b) => b.classList.contains("active"))?.dataset
        .filter ?? "all";
    state.controller?.abort();
    state.controller = new AbortController();
    setActive(filter);

    try {
      const html = await loadFragment(fragmentUrl, state.controller.signal);
      const incoming = parseFeedSection(html);
      await replaceFeedSection(current, incoming);
      if (mode === "push") {
        history.pushState({ feedFilter: filter }, "", button.dataset.routeUrl);
      } else {
        history.replaceState(
          { feedFilter: filter },
          "",
          button.dataset.routeUrl,
        );
      }
      document.dispatchEvent(new CustomEvent("feed:replaced"));
    } catch (err) {
      if (err instanceof DOMException && err.name === "AbortError") return;
      console.error("Feed filter fetch failed:", err);
      setActive(previousFilter);
    } finally {
      if (!state.controller?.signal.aborted) {
        state.controller = null;
      }
    }
  }

  function onClick(event: MouseEvent) {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const button = target.closest<HTMLButtonElement>(
      ".filter-btn[data-filter][data-fragment-url][data-route-url]",
    );
    if (!button) return;

    event.preventDefault();
    event.stopPropagation();
    event.stopImmediatePropagation();

    if (button.classList.contains("active")) return;
    applyFilter(button);
  }

  function onPopState() {
    const filter = filterForPath(window.location.pathname);
    const button = getButtons().find((b) => b.dataset.filter === filter);
    if (button) applyFilter(button, "replace");
  }

  function prefetchAll() {
    getButtons().forEach((button) => prefetch(button));
  }

  function bind() {
    if (state.bound) return;
    cacheCurrentSection();
    history.replaceState(
      { feedFilter: filterForPath(window.location.pathname) },
      "",
      window.location.href,
    );
    document.addEventListener("click", onClick, { capture: true });
    document.addEventListener("mouseover", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const button = target.closest<HTMLButtonElement>(
        ".filter-btn[data-fragment-url]",
      );
      if (button) prefetch(button);
    });
    window.addEventListener("popstate", onPopState);
    if ("requestIdleCallback" in window) {
      window.requestIdleCallback(prefetchAll);
    } else {
      window.setTimeout(prefetchAll, 250);
    }
    state.bound = true;
  }

  bind();
</script>

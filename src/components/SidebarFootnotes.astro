---
// Component for displaying footnotes in the sidebar overlay
// Footnotes are positioned next to their references inside the right rail.
---

<aside id="sidebar-footnotes" class="footnotes-overlay">
  <!-- Individual footnotes will be positioned here -->
</aside>

<style>
  .footnotes-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    --footnote-text-opacity: 0.35;
  }

  @media (max-width: 1535px) {
    .footnotes-overlay {
      display: none;
    }
  }

  :global(.footnote-item) {
    position: absolute;
    left: 1.25rem;
    width: calc(100% - 2rem);
    max-width: 17.5rem;
    @apply px-2 py-1 text-sm;
    pointer-events: auto;
    color: var(--color-text-base);
    line-height: 1.4;
    opacity: 0;
    transition:
      opacity 0.25s ease,
      filter 0.25s ease;
  }

  :global(.footnote-item.visible) {
    opacity: 0.85;
  }

  :global(.footnote-item.fading-top) {
    filter: blur(2px);
    opacity: 0.18;
  }

  :global(.footnote-item.fading-bottom) {
    filter: blur(2px);
    opacity: 0.3;
  }

  :global(.footnote-number) {
    @apply mr-2 inline-block font-bold;
    color: var(--color-accent);
    opacity: var(--footnote-text-opacity);
    font-size: 0.875rem;
  }

  :global(.footnote-content) {
    @apply inline;
    opacity: var(--footnote-text-opacity);
  }

  :global(.footnote-content p) {
    @apply inline;
    margin: 0;
  }

  :global(.footnote-content a) {
    @apply text-skin-accent hover:underline;
  }

  :global(.footnote-content [data-footnote-backref]) {
    display: none;
  }

  :global(.footnote-item:hover),
  :global(.footnote-item.active) {
    opacity: 1 !important;
    filter: blur(0) !important;
    z-index: 20;
  }

  :global(.footnote-item:hover .footnote-number),
  :global(.footnote-item.active .footnote-number) {
    color: var(--color-accent);
    opacity: 1;
    text-shadow: 0 0 4px rgba(var(--color-accent), 0.3);
  }

  :global(.footnote-item:hover .footnote-content),
  :global(.footnote-item.active .footnote-content) {
    opacity: 1;
  }

  :global(sup.footnote-ref-active),
  :global(.footnote-ref-active) {
    color: var(--color-accent) !important;
    font-weight: 700;
  }

  :global(sup.footnote-ref-active a),
  :global(.footnote-ref-active a) {
    color: var(--color-accent) !important;
  }
</style>

<script>
  (() => {
    const cleanupKey = "__cleanupSidebarFootnotes";
    const setupKey = "__sidebarFootnotesSetup";

    function cleanup() {
      if (typeof window[cleanupKey] === "function") {
        window[cleanupKey]();
      }
      window[cleanupKey] = undefined;
    }

    function initSidebarFootnotes() {
      cleanup();

      const overlayElement = document.getElementById("sidebar-footnotes");
      const articleElement = document.getElementById("article");
      const contentContainer = overlayElement?.parentElement;
      const footnotesSection = document.querySelector(
        "section[data-footnotes]",
      );

      if (
        !overlayElement ||
        !articleElement ||
        !contentContainer ||
        !footnotesSection
      ) {
        return;
      }

      const footnoteItems = Array.from(
        footnotesSection.querySelectorAll<HTMLElement>(
          'li[id^="user-content-fn-"]',
        ),
      );
      if (footnoteItems.length === 0) return;

      overlayElement.innerHTML = "";

      const controller = new AbortController();
      const { signal } = controller;
      const resizeObserver = new ResizeObserver(() => scheduleMeasure());
      const trackedImages = Array.from(
        articleElement.querySelectorAll<HTMLImageElement>("img"),
      );

      const footnoteElements = footnoteItems
        .map((footnote, index) => {
          const footnoteId = footnote.id;
          const refId = footnoteId.replace(
            "user-content-fn-",
            "user-content-fnref-",
          );
          const refElement = document.getElementById(refId);
          const refLink = document.querySelector(`a[href="#${footnoteId}"]`);
          if (
            !(refElement instanceof HTMLElement) ||
            !(refLink instanceof HTMLAnchorElement)
          ) {
            return null;
          }

          const sidebarFootnote = document.createElement("div");
          sidebarFootnote.className = "footnote-item";
          sidebarFootnote.dataset.footnoteId = footnoteId;
          sidebarFootnote.dataset.refId = refId;
          sidebarFootnote.innerHTML = `
            <span class="footnote-number">${index + 1}.</span>
            <div class="footnote-content">${footnote.innerHTML}</div>
          `;

          overlayElement.appendChild(sidebarFootnote);

          return {
            element: sidebarFootnote,
            refElement,
            refLink,
          };
        })
        .filter(Boolean);

      if (footnoteElements.length === 0) {
        overlayElement.innerHTML = "";
        return;
      }

      let measureQueued = false;
      let scrollQueued = false;
      let activeTimeout = null;

      function clearActive() {
        footnoteElements.forEach(({ element, refElement }) => {
          element.classList.remove("active");
          refElement.classList.remove("footnote-ref-active");
          refElement.closest("sup")?.classList.remove("footnote-ref-active");
        });
      }

      function scheduleClearActive(delay = 2500) {
        if (activeTimeout) window.clearTimeout(activeTimeout);
        activeTimeout = window.setTimeout(() => {
          clearActive();
          activeTimeout = null;
        }, delay);
      }

      function updateFootnotePositions() {
        const containerRect = contentContainer.getBoundingClientRect();
        const containerTop = containerRect.top + window.scrollY;
        let previousBottom = 0;

        footnoteElements.forEach(({ element, refElement }) => {
          const refTop =
            refElement.getBoundingClientRect().top + window.scrollY;
          const minTop = previousBottom === 0 ? 0 : previousBottom + 16;
          const topPosition = Math.max(refTop - containerTop, minTop);

          element.style.top = `${topPosition}px`;
          previousBottom = topPosition + element.offsetHeight;
        });
      }

      function updateFootnoteVisibility() {
        const viewportTop = 0;
        const viewportBottom = window.innerHeight;

        footnoteElements.forEach(({ element }) => {
          const rect = element.getBoundingClientRect();
          element.classList.remove("visible", "fading-top", "fading-bottom");

          const isVisible =
            rect.bottom > viewportTop && rect.top < viewportBottom;
          if (!isVisible) return;

          element.classList.add("visible");

          if (rect.top < 72) {
            element.classList.add("fading-top");
          }
          if (viewportBottom - rect.top < 120) {
            element.classList.add("fading-bottom");
          }
        });
      }

      function scheduleMeasure() {
        if (measureQueued) return;
        measureQueued = true;
        requestAnimationFrame(() => {
          updateFootnotePositions();
          updateFootnoteVisibility();
          measureQueued = false;
        });
      }

      function onScroll() {
        if (scrollQueued) return;
        scrollQueued = true;
        requestAnimationFrame(() => {
          updateFootnoteVisibility();
          scrollQueued = false;
        });
      }

      footnoteElements.forEach(({ element, refElement, refLink }) => {
        const activate = () => {
          clearActive();
          element.classList.add("active");
          refElement.classList.add("footnote-ref-active");
          refElement.closest("sup")?.classList.add("footnote-ref-active");
        };

        refLink.addEventListener("mouseenter", activate, { signal });
        refLink.addEventListener(
          "mouseleave",
          () => {
            element.classList.remove("active");
            refElement.classList.remove("footnote-ref-active");
            refElement.closest("sup")?.classList.remove("footnote-ref-active");
          },
          { signal },
        );

        refLink.addEventListener(
          "click",
          (event) => {
            event.preventDefault();
            activate();
            refElement.scrollIntoView({ behavior: "smooth", block: "center" });
            scheduleClearActive();
          },
          { signal },
        );

        element.addEventListener("mouseenter", activate, { signal });
        element.addEventListener(
          "mouseleave",
          () => {
            element.classList.remove("active");
            refElement.classList.remove("footnote-ref-active");
            refElement.closest("sup")?.classList.remove("footnote-ref-active");
          },
          { signal },
        );

        element.addEventListener(
          "click",
          () => {
            activate();
            refElement.scrollIntoView({ behavior: "smooth", block: "center" });
            scheduleClearActive();
          },
          { signal },
        );
      });

      resizeObserver.observe(articleElement);
      resizeObserver.observe(contentContainer);
      resizeObserver.observe(overlayElement);

      trackedImages.forEach((image) => {
        if (!image.complete) {
          image.addEventListener("load", scheduleMeasure, {
            once: true,
            signal,
          });
          image.addEventListener("error", scheduleMeasure, {
            once: true,
            signal,
          });
        }
      });

      window.addEventListener("resize", scheduleMeasure, { signal });
      window.addEventListener("scroll", onScroll, { passive: true, signal });
      window.addEventListener("load", scheduleMeasure, { once: true, signal });

      scheduleMeasure();

      window[cleanupKey] = () => {
        if (activeTimeout) {
          window.clearTimeout(activeTimeout);
        }
        controller.abort();
        resizeObserver.disconnect();
        overlayElement.innerHTML = "";
      };
    }

    if (!window[setupKey]) {
      window[setupKey] = true;
      document.addEventListener("astro:before-swap", cleanup);
      document.addEventListener("astro:page-load", initSidebarFootnotes);

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initSidebarFootnotes, {
          once: true,
        });
      } else {
        initSidebarFootnotes();
      }
    } else {
      initSidebarFootnotes();
    }
  })();
</script>

---
import type { CollectionEntry } from "astro:content";
import FeedCard from "@components/FeedCard.astro";
import FeedItems from "@components/FeedItems.astro";
import getPostType from "@utils/getPostType";

interface Props {
  featuredPosts?: CollectionEntry<"blog">[];
  posts: CollectionEntry<"blog">[];
  nextPage: string | null;
}

const { featuredPosts = [], posts, nextPage } = Astro.props;

function stripMarkdown(text: string): string {
  return text
    .replace(/<[^>]+>/g, " ")
    .replace(/```[\s\S]*?```/g, "")
    .replace(/`[^`]+`/g, "")
    .replace(/^#+\s+/gm, "")
    .replace(/\*\*|__/g, "")
    .replace(/[*_]/g, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/^\s*[-*+]\s+/gm, "")
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 500);
}
---

<div id="feed-section">
  {featuredPosts.length > 0 && (
    <div id="featured-section" class="mb-6">
      <div class="featured-grid">
        {featuredPosts.map(post => (
          <div
            data-post-type={getPostType(post)}
            data-featured="true"
            class="feed-item featured-grid-item"
          >
            <div class="featured-card-content">
              <FeedCard post={post} featured={true} />
            </div>
            <p class="article-preview" aria-hidden="true">
              {stripMarkdown(post.body ?? "")}
            </p>
          </div>
        ))}
      </div>
    </div>
  )}
  <FeedItems posts={posts} nextPage={nextPage} />
</div>

<style>
  .featured-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .featured-grid-item {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(var(--color-border));
    border-radius: 0.5rem;
    padding: 1rem;
    transition: background-color 0.15s ease;
  }
  .featured-grid-item:hover {
    background-color: rgba(var(--color-card), 0.18);
  }
  .featured-card-content {
    position: relative;
    z-index: 1;
  }
  :global(.featured-grid-item article) {
    padding-top: 0;
    padding-bottom: 0;
  }
  .article-preview {
    position: absolute;
    bottom: 0;
    right: 1rem;
    left: 1rem;
    height: 2.75rem;
    margin: 0;
    font-size: 0.6rem;
    line-height: 1.5;
    text-align: right;
    color: rgb(var(--color-text-base));
    opacity: 0.22;
    pointer-events: none;
    overflow: hidden;
    -webkit-mask-image:
      linear-gradient(to bottom, transparent 30%, black 85%),
      linear-gradient(to right, transparent 10%, black 50%);
    mask-image:
      linear-gradient(to bottom, transparent 30%, black 85%),
      linear-gradient(to right, transparent 10%, black 50%);
    -webkit-mask-composite: source-in;
    mask-composite: intersect;
    z-index: 0;
  }
</style>
